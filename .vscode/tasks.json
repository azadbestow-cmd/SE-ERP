{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build APK",
            "type": "shell",
            "command": "flutter build apk --split-per-abi",
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "echo": true, "reveal": "always" }
        },
        {
            "label": "Clean Project",
            "type": "shell",
            "command": "flutter clean",
            "group": "build"
        }
    ]
}